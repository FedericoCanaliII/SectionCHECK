            <item>
             <widget class="QPlainTextEdit" name="struttura_plainTextEdit">
              <property name="minimumSize">
               <size>
                <width>1200</width>
                <height>0</height>
               </size>
              </property>
              <property name="maximumSize">
               <size>
                <width>1200</width>
                <height>16777215</height>
               </size>
              </property>
              <property name="styleSheet">
               <string notr="true">/* =========================================
   STILE PRINCIPALE QPLAINTEXTEDIT
   ========================================= */
QPlainTextEdit {
	color: rgb(212, 212, 212);
    selection-background-color: rgb(38, 79, 120);
    selection-color: rgb(255, 255, 255);
    background-color: rgb(50,50,50);
    color: white; /* Consigliato per contrastare il fondo scuro */
    border: 1px solid rgb(120,120,120);
    border-left: 3px solid rgb(120,120,120);
    border-top: none; /* Opzionale: rimuove il bordo superiore */
    padding: 4px; /* Aggiunge un po' di respiro al testo */
}

/* =========================================
   SCROLLBAR VERTICALE
   ========================================= */
QScrollBar:vertical {
    background: transparent;
    width: 8px;
    margin: 0px;
}

QScrollBar::handle:vertical {
    background-color: rgb(120,120,120);
    min-height: 30px;
    border-radius: 4px;
}

/* Nasconde completamente tutti gli altri elementi della scrollbar verticale */
QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical,
QScrollBar::up-arrow:vertical,
QScrollBar::down-arrow:vertical,
QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical {
    background: none;
    border: none;
    height: 0px;
}

/* =========================================
   SCROLLBAR ORIZZONTALE
   ========================================= */
QScrollBar:horizontal {
    background: transparent;
    height: 8px; 
    margin: 0px;
}

QScrollBar::handle:horizontal {
    background-color: rgb(120,120,120);
    min-width: 30px; 
    border-radius: 4px;
}

/* Nasconde completamente tutti gli altri elementi della scrollbar orizzontale */
QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal,
QScrollBar::left-arrow:horizontal,
QScrollBar::right-arrow:horizontal,
QScrollBar::add-page:horizontal,
QScrollBar::sub-page:horizontal {
    background: none;
    border: none;
    width: 0px; 
}</string>
              </property>
             </widget>
