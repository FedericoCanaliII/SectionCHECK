            <property name="styleSheet">
             <string notr="true">/* 1. Applica il bordo e lo sfondo SOLO alla cornice esterna */
QWidget {
    border-radius: 6px;
    background-color: rgb(50, 50, 50);
	border: 1px solid rgb(120,120,120);
	border-left: 3px solid rgb(120,120,120);
}

/* 2. Rende il viewport e il widget interno completamente trasparenti */
/* Rimuovendo 'border' qui, il doppio bordo scompare */
#qt_scrollarea_viewport, 
QScrollArea &gt; QWidget &gt; QWidget {
    border: none;
    background: transparent;
    background-color: transparent;
}

/* 3. Gestione Scrollbar (completamente invisibile) */
QScrollBar:vertical {
    width: 0px;
    background: transparent;
}

QScrollBar::handle:vertical {
    background: none;
    border: none;
}

QScrollBar::add-line:vertical, 
QScrollBar::sub-line:vertical,
QScrollBar::add-page:vertical, 
QScrollBar::sub-page:vertical {
    width: 0px;
    height: 0px;
    background: none;
}</string>
